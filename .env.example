# Mealytics — Environment Variables
# Copy this file to .env and fill in your values

# ── Database ──────────────────────────────────────────────
DB_PASSWORD=CHANGE_ME_strong_random_password

# ── JWT ───────────────────────────────────────────────────
# IMPORTANT: Change this to a strong random secret in production!
# Generate with: openssl rand -hex 64
JWT_SECRET=change_me_in_production_please
JWT_EXPIRES=1d

# ── Backend ───────────────────────────────────────────────
# The public URL of the frontend (used for CORS).
# In production, set this to your actual domain, e.g. https://mealytics.example.com
FRONTEND_URL=http://localhost:8043

# ── App (Docker) ──────────────────────────────────────────
# Host port the app will be exposed on.
APP_PORT=8043
